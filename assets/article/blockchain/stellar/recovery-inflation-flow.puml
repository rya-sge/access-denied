@startuml
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Helvetica
skinparam activity {
  BackgroundColor #E8F0FA
  BorderColor #4A6FA5
  DiamondBackgroundColor #FFF6E0
  DiamondBorderColor #C79100
}
<style>
.bad { BackgroundColor #FADBD8 }
</style>

title recovery_address(lost, new) with lost == new == A  (vulnerable v0.5.0)

start
:caller passes lost = A, new = A;
note right
  No require_auth.
  Only verify_identity(new) is checked,
  and A already passes it.
end note

:lost_balance = Base::balance(A) = b;
:new_balance = Base::balance(A) + lost_balance\n= b + b = 2b;

partition "read-read-write on the SAME key" {
  :write Balance(A) = 0;
  :write Balance(A) = 2b;
}

:emit transfer(A, A, b);

if (total_supply updated?) then (no)
  :Sum of balances += b\ntotal_supply unchanged\nINVARIANT BROKEN; <<bad>>
else (yes)
endif

if (call again with (A, A)?) then (yes)
  :b -> 2b -> 4b -> 8b ...\nexponential mint; <<bad>>
  detach
else (no)
endif

stop

@enduml
